{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Coding Throughput (records/hour)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "vigilex-postgres-uid"
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex-postgres-uid"
          },
          "rawSql": "SELECT\n  date_trunc('hour', coded_at) AS time,\n  COUNT(*) AS records_coded\nFROM processed.coding_results\nWHERE coded_at >= NOW() - INTERVAL '7 days'\nGROUP BY 1\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Top 15 Adverse Events (PT codes, LZG)",
      "type": "barchart",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "vigilex-postgres-uid"
      },
      "options": {
        "orientation": "horizontal",
        "barWidth": 0.7,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "hidden"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex-postgres-uid"
          },
          "rawSql": "SELECT\n  pt_name,\n  COUNT(*) AS n_reports\nFROM processed.coding_results\nGROUP BY pt_name\nORDER BY n_reports DESC\nLIMIT 15",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Confidence Score Distribution",
      "type": "histogram",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "vigilex-postgres-uid"
      },
      "options": {
        "bucketSize": "auto",
        "fillOpacity": 80,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex-postgres-uid"
          },
          "rawSql": "SELECT final_confidence FROM processed.coding_results WHERE final_confidence IS NOT NULL",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Coding Quality Summary",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "vigilex-postgres-uid"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex-postgres-uid"
          },
          "rawSql": "SELECT COUNT(*) AS \"Total Coded\" FROM processed.coding_results",
          "format": "table",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex-postgres-uid"
          },
          "rawSql": "SELECT ROUND(AVG(final_confidence)::numeric, 3) AS \"Avg Confidence\" FROM processed.coding_results",
          "format": "table",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex-postgres-uid"
          },
          "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN final_confidence >= 0.7 THEN 1 ELSE 0 END) / COUNT(*)::numeric, 1) AS \"High Conf %\" FROM processed.coding_results",
          "format": "table",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex-postgres-uid"
          },
          "rawSql": "SELECT COUNT(DISTINCT pt_name) AS \"Unique PTs\" FROM processed.coding_results",
          "format": "table",
          "refId": "D"
        }
      ]
    }
  ],
  "refresh": "30s",
