{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Coding Throughput (records/hour)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "vigilex_pg"
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex_pg"
          },
          "rawSql": "SELECT\n  date_trunc('hour', coded_at) AS time,\n  COUNT(*) AS records_coded\nFROM processed.coding_results\nWHERE coded_at >= NOW() - INTERVAL '7 days'\n  AND coding_path IS NOT NULL\nGROUP BY 1\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Ranking Index Distribution",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "vigilex_pg"
      },
      "options": {
        "orientation": "auto",
        "xField": "bucket_start",
        "fillOpacity": 80,
        "barWidth": 0.9,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex_pg"
          },
          "rawSql": "SELECT\n  ROUND((width_bucket(final_confidence, 0.0, 1.0, 10) - 1) * 0.1, 1) AS bucket_start,\n  COUNT(*) AS n\nFROM processed.coding_results\nWHERE coding_path = 'hybrid_ce_llm_success'\n  AND final_confidence IS NOT NULL\n  AND final_confidence > 0\nGROUP BY 1\nORDER BY 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Triage Categories (Post-Fix Records)",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "vigilex_pg"
      },
      "options": {
        "orientation": "auto",
        "xField": "category",
        "xTickLabelRotation": 0,
        "barWidth": 0.7,
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "01 Flag for Review"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "#E05252"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "02 Uncertain"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "#E8C84A"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "03 Accept"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "#52B788"}}
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex_pg"
          },
          "rawSql": "SELECT\n  'Distribution' AS category,\n  COUNT(*) FILTER (WHERE final_confidence < 0.30)                              AS \"01 Flag for Review\",\n  COUNT(*) FILTER (WHERE final_confidence >= 0.30 AND final_confidence < 0.65) AS \"02 Uncertain\",\n  COUNT(*) FILTER (WHERE final_confidence >= 0.65)                             AS \"03 Accept\"\nFROM processed.coding_results\nWHERE final_confidence > 0\n  AND coding_path = 'hybrid_ce_llm_success'",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "System Summary",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "vigilex_pg"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex_pg"
          },
          "rawSql": "SELECT COUNT(*) AS \"Total Coded\" FROM processed.coding_results WHERE coding_path IS NOT NULL",
          "format": "table",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex_pg"
          },
          "rawSql": "SELECT 62.5 AS \"Soft Recall@5 (%)\"",
          "format": "table",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex_pg"
          },
          "rawSql": "SELECT 83.3 AS \"Soft Recall@10 (%)\"",
          "format": "table",
          "refId": "D"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "vigilex_pg"
          },
          "rawSql": "SELECT COUNT(DISTINCT pt_name) AS \"Unique PTs\" FROM processed.coding_results WHERE coding_path IS NOT NULL",
          "format": "table",
          "refId": "E"
        }
      ]
    },
