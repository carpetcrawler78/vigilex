          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT mdr_report_key, pt_name, pt_code, llt_name, soc_name, ROUND(final_confidence::numeric, 3) AS confidence, ROUND(crossencoder_score::numeric, 3) AS crossencoder, coded_at FROM processed.coding_results WHERE coding_path IS NOT NULL ORDER BY coded_at DESC LIMIT 2000",
